#!/bin/bash

# Load password from .env if not set in environment
if [ -z "$MYSQL_ROOT_PASSWORD" ]; then
  SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
  ENV_FILE="$SCRIPT_DIR/../.env"
  if [ -f "$ENV_FILE" ]; then
    MYSQL_ROOT_PASSWORD=$(grep -E '^MYSQL_ROOT_PASSWORD=' "$ENV_FILE" | cut -d'=' -f2-)
  fi
fi

if [ -z "$MYSQL_ROOT_PASSWORD" ]; then
  echo "Error: MYSQL_ROOT_PASSWORD is not set. Set it in .env or export it." >&2
  exit 1
fi

BACKUP_FILE=$1
USER="root"
HOST="nsx.malloc.tokyo"
REMOTE_DIR="/home/deploy/nsx/"

if [ -z "$BACKUP_FILE" ]; then
  echo "Usage: ./scripts/restore <backup file name>"
  exit 1
fi

# Transfer backup file to remote server
scp ${BACKUP_FILE} ${USER}@${HOST}:${REMOTE_DIR}/

# Restore database on remote server
ssh ${USER}@${HOST} "docker exec -i nsx-db-1 mysql -u root -p${MYSQL_ROOT_PASSWORD} digital < ${REMOTE_DIR}/$(basename ${BACKUP_FILE})"

echo "Remote server database restore completed"
