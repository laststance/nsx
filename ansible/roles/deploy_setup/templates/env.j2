VITE_APP_TITLE={{ "NSX" | to_json }}
VITE_APP_DESCRIPTION={{ "Just logging tech resources I read." | to_json }}
VITE_API_ENDPOINT={{ ("https://" ~ app_domain ~ "/api/") | to_json }}
VITE_SENTRY_DSN={{ vault_vite_sentry_dsn | default("") | to_json }}
VITE_SENTRY_DNS={{ vault_vite_sentry_dsn | default("") | to_json }}
VITE_SENTRY_RELEASE={{ app_version | to_json }}
VITE_GA_MEASUREMENT_ID={{ vault_ga_measurement_id | default("") | to_json }}

ACCESS_TOKEN_SECRET={{ vault_access_token_secret | mandatory | to_json }}
REFRESH_TOKEN_SECRET={{ vault_refresh_token_secret | mandatory | to_json }}
SENTRY_DSN={{ vault_sentry_dsn | default("") | to_json }}
SENTRY_RELEASE={{ app_version | to_json }}
SENTRY_TRACES_SAMPLE_RATE={{ vault_sentry_traces_sample_rate | default("0.1") | to_json }}
LOG_LEVEL={{ vault_log_level | default("info") | to_json }}

{% set mysql_socket_path = app_dir ~ "/run/mysqld/mysqld.sock" %}
DATABASE_URL={{ vault_database_url | default("mysql://root:" ~ (vault_mysql_root_password | urlencode) ~ "@localhost/digital?socketPath=" ~ (mysql_socket_path | urlencode)) | to_json }}
MYSQL_ROOT_PASSWORD={{ vault_mysql_root_password | mandatory | to_json }}
MYSQL_USER={{ vault_mysql_user | default("strength") | to_json }}
MYSQL_PASSWORD={{ vault_mysql_password | mandatory | to_json }}

CORS_ORIGIN={{ ("https://" ~ app_domain) | to_json }}

SSL_DOMAIN={{ app_domain | to_json }}
SSL_BASE_PATH={{ ("/etc/letsencrypt/live/" ~ app_domain) | to_json }}
SSL_KEY_PATH={{ ("/etc/letsencrypt/live/" ~ app_domain ~ "/privkey.pem") | to_json }}
SSL_CERT_PATH={{ ("/etc/letsencrypt/live/" ~ app_domain ~ "/cert.pem") | to_json }}
SSL_CA_PATH={{ ("/etc/letsencrypt/live/" ~ app_domain ~ "/chain.pem") | to_json }}

BACKUP_ROOT={{ (app_dir ~ "/backups") | to_json }}
BACKUP_DATABASE_NAME={{ "digital" | to_json }}
BACKUP_DOCKER_CONTAINER={{ (app_name ~ "-db-1") | to_json }}
BACKUP_GPG_RECIPIENT={{ vault_backup_gpg_recipient | mandatory | to_json }}
BACKUP_OFFSITE_RSYNC_TARGET={{ vault_backup_offsite_rsync_target | mandatory | to_json }}
BACKUP_REQUIRE_OFFSITE={{ vault_backup_require_offsite | default(1) }}
BACKUP_ALERT_WEBHOOK_URL={{ vault_backup_alert_webhook_url | default("") | to_json }}
BACKUP_ALERT_ON_SUCCESS={{ vault_backup_alert_on_success | default(0) }}
BACKUP_DAILY_KEEP={{ vault_backup_daily_keep | default(7) }}
BACKUP_WEEKLY_KEEP={{ vault_backup_weekly_keep | default(4) }}
BACKUP_MONTHLY_KEEP={{ vault_backup_monthly_keep | default(3) }}
